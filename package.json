{
  "name": "iamsteve",
  "version": "8.5.15",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "icons": "node scripts/generate-icon-sprite.js",
    "post": "node ./scripts/compose.js",
    "note": "node ./scripts/compose-note.js",
    "validate:links": "node scripts/validate-collection-links.js",
    "validate:links:all": "CHECK_ALL=true node scripts/validate-collection-links.js",
    "prepare": "husky"
  },
  "browserslist": [
    "> 2%",
    "not dead",
    "not op_mini all"
  ],
  "pnpm": {
    "overrides": {
      "whatwg-url": "13.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@content-collections/core": "^0.14.2",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@jsdevtools/rehype-toc": "^3.0.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/bundle-analyzer": "^16.2.0",
    "@next/mdx": "^16.2.0",
    "@shikijs/rehype": "^4.0.0",
    "@shikijs/transformers": "^4.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.86.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.1.3",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "dedent": "^0.7.0",
    "encoding": "^0.1.13",
    "esbuild": "^0.25.0",
    "eslint-config-next": "^16.2.0",
    "feed": "^4.2.2",
    "github-slugger": "^2.0.0",
    "globby": "^11.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^8.2.7",
    "marked": "^14.1.4",
    "mdast-util-to-string": "^4.0.0",
    "motion": "^12.23.25",
    "next": "^16.2.0",
    "postcss": "^8.5.6",
    "postcss-nesting": "^12.1.5",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-aria-components": "^1.14.0",
    "react-dom": "19.0.0",
    "react-intersection-observer": "^9.16.0",
    "reading-time": "^1.5.0",
    "rehype": "^13.0.2",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-citation": "^1.0.3",
    "rehype-code-titles": "^1.2.1",
    "rehype-parse": "^8.0.5",
    "rehype-slug": "^5.1.0",
    "rehype-stringify": "^9.0.4",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^10.1.0",
    "remark-smartypants": "^2.1.0",
    "sharp": "^0.32.6",
    "shiki": "^4.0.0",
    "swr": "^1.3.0",
