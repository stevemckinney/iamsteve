{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/data/*": ["data/*"],
      "@/layouts/*": ["layouts/*"],
      "@/content/*": ["content/*"],
      "@/lib/*": ["lib/*"],
      "@/css/*": ["css/*"],
      "@/images/*": ["/public/images/*"],
      "content-collections": ["./.content-collections/generated"]
    }
  },
  "include": [".content-collections/generated"]
}
