---
/**
 * SVG sprite component for Astro.
 *
 * Reads the combined sprite-all.svg generated by scripts/generate-icon-sprite.js
 * which contains all 16px and 24px icons with proper class transformations.
 *
 * Also injects the logo symbols which are maintained separately.
 */
import fs from 'node:fs'
import path from 'node:path'

const spritePath = path.join(process.cwd(), 'public/icon/sprite-all.svg')
let spriteContent = ''

try {
  const raw = fs.readFileSync(spritePath, 'utf-8')
  // Extract just the content inside <defs>...</defs>
  const match = raw.match(/<defs>([\s\S]*)<\/defs>/)
  spriteContent = match ? match[1] : ''
} catch {
  // Fallback: sprite not yet generated
}

// Also handle JSX-style attributes that the script outputs
// Convert fillRule, clipPath, clipRule, strokeDasharray etc. back to HTML
spriteContent = spriteContent
  .replace(/fillRule=/g, 'fill-rule=')
  .replace(/clipPath=/g, 'clip-path=')
  .replace(/clipRule=/g, 'clip-rule=')
  .replace(/strokeDasharray=/g, 'stroke-dasharray=')
  .replace(/strokeDashoffset=/g, 'stroke-dashoffset=')
  .replace(/strokeMiterlimit=/g, 'stroke-miterlimit=')
  .replace(/strokeWidth=/g, 'stroke-width=')
  .replace(/strokeLinecap=/g, 'stroke-linecap=')
  .replace(/strokeLinejoin=/g, 'stroke-linejoin=')
  // Convert JSX style objects to HTML style strings
  .replace(/style=\{\{\s*maskType:\s*'alpha'\s*\}\}/g, 'style="mask-type:alpha"')

const logoSymbols = `
<symbol id="logo-32" viewBox="0 0 32 32" fill="none">
  <title>iamsteve</title>
  <path d="M17.5 30.5C16.65 26.02 17.91 20.71 19.5 18.5C22.47 18.4 25.62 17.68 28.06 15.5C30.04 13.49 30.43 10.58 30.5 8.5L24.5 7.5L22.5 3.5L21.5 4.5L19.5 1.5L17.83 2.41C17.83 2.41 15 0.56 11.5 2.5C8.41 4.37 7 7 7.5 11.5C8 16 5.079 18.921 1.5 22.5C1.5 22.5 7 23 10 24.5C13 26 17.5 30.5 17.5 30.5Z" class="fill-(--icon-fill)" />
  <path d="M17.5 30.5C16.65 26.02 17.91 20.71 19.5 18.5C22.47 18.4 25.62 17.68 28.06 15.5C30.04 13.49 30.43 10.58 30.5 8.5L24.5 7.5L22.5 3.5L21.5 4.5L19.5 1.5L17.83 2.41C17.83 2.41 15 0.56 11.5 2.5C8.40996 4.37 6.72996 7.69 7.49996 11.5C7.99996 13.95 9.75996 16.5 12.5 16.5C16.5 16.5 18.25 12.36 18.5 7.5" class="stroke-current stroke-2 sl-r" />
  <path d="M1.5 22.5C4.41 20.2 7.87 16.23 7.5 11.5" class="stroke-current stroke-2 sl-r" />
</symbol>
<symbol id="logo-24" viewBox="0 0 24 24" fill="none">
  <title>iamsteve</title>
  <path d="M13.125 22.875C12.4875 19.515 13.1825 15.5325 14.375 14.375C16.6025 14.3 18.965 13.76 20.795 12.125C22.28 10.6175 22.5725 8.435 22.625 6.875L18.375 6.125L16.875 2.875L16.125 3.625L14.625 1.375L13.3725 1.8075C13.3725 1.8075 11.25 0.42 8.625 1.875C6.3075 3.2775 5.25 5.25 5.625 8.625C6 12 3.8093 14.1908 1.125 16.875C1.125 16.875 5.25 17.25 7.5 18.375C9.75 19.5 13.125 22.875 13.125 22.875Z" class="fill-(--icon-fill)" />
  <path d="M13.125 22.875C12.4875 19.515 13.1825 15.5325 14.375 14.375C16.6025 14.3 18.965 13.76 20.795 12.125C22.28 10.6175 22.5725 8.435 22.625 6.875L18.375 6.125L16.875 2.875L16.125 3.625L14.625 1.375L13.3725 1.8075C13.3725 1.8075 11.25 0.42 8.625 1.875C6.30747 3.2775 5.04747 5.7675 5.62497 8.625C5.99997 10.4625 7.31997 12.375 9.375 12.375C12.375 12.375 13.6875 9.27 13.875 5.625" class="stroke-current stroke-2 sl-r" />
  <path d="M1.125 16.875C3.3075 15.15 5.9025 12.1725 5.625 8.625" class="stroke-current stroke-2 sl-r" />
</symbol>`
---

<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;display:none">
  <defs>
    <Fragment set:html={spriteContent} />
    <Fragment set:html={logoSymbols} />
  </defs>
</svg>
