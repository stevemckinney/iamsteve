---
import Blog from '../../../../layouts/Blog.astro'
import { getCollection } from 'astro:content'
import Card from '../../../../components/Card.astro'
import categories from '../../../../../content/categories.js'

const POSTS_PER_PAGE = 12

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 12
  const cats = (await import('../../../../../content/categories.js')).default
  const allPosts = await getCollection('blog', ({ data }) => data.status === 'open')
  const paths: any[] = []

  for (const cat of cats) {
    const childSlugs = cats
      .filter((c: any) => c.parent === cat.slugAsParams || c.slugAsParams === cat.slugAsParams)
      .map((c: any) => c.title)

    const catPosts = allPosts.filter((p) =>
      p.data.categories.some((pc: string) =>
        childSlugs.some((cs: string) => cs.toLowerCase() === pc.toLowerCase())
      )
    )

    const totalPages = Math.ceil(catPosts.length / POSTS_PER_PAGE)
    for (let i = 2; i <= totalPages; i++) {
      paths.push({ params: { slug: cat.slugAsParams, page: String(i) } })
    }
  }

  return paths
}

const { slug, page } = Astro.params
const pageNumber = parseInt(page!)
const category = categories.find((c: any) => c.slugAsParams === slug)

const childSlugs = categories
  .filter((c: any) => c.parent === slug || c.slugAsParams === slug)
  .map((c: any) => c.title)

const allPosts = await getCollection('blog', ({ data }) => {
  if (data.status !== 'open') return false
  return data.categories.some((cat: string) =>
    childSlugs.some((cs: string) => cs.toLowerCase() === cat.toLowerCase())
  )
})

const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
const paginatedPosts = posts.slice(POSTS_PER_PAGE * (pageNumber - 1), POSTS_PER_PAGE * pageNumber)
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE)
---

<Blog title={`${category?.title} \u2013 Page ${pageNumber}`} description={category?.description}>
  <header class="max-md:frame max-md:frame-24 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 col-container md:col-content max-md:px-8 max-md:py-12">
    <div class="flex flex-col gap-4 md:col-span-1">
      <h1 class="w-full text-heading font-display lowercase self-start min-w-0 min-h-0 font-variation-bold lg:font-variation-extrabold text-3xl xs:text-5xl lg:text-7xl">
        {category?.title}
      </h1>
      <p class="md:text-lg lg:text-xl text-ui-body sm:max-w-[34ch]">Page {pageNumber} of {totalPages}</p>
    </div>
  </header>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 col-container md:col-content gap-8">
    {paginatedPosts.map((post) => <Card post={post} image={true} size="container" />)}
  </div>
  <nav class="col-content flex items-center justify-center gap-4 pt-8" aria-label="Pagination">
    {pageNumber > 1 && (
      <a href={pageNumber === 2 ? `/category/${slug}` : `/category/${slug}/page/${pageNumber - 1}`} class="text-emphasis hover:text-link-hover transition duration-200">
        &larr; Previous
      </a>
    )}
    <span class="text-ui-body opacity-50">Page {pageNumber} of {totalPages}</span>
    {pageNumber < totalPages && (
      <a href={`/category/${slug}/page/${pageNumber + 1}`} class="text-emphasis hover:text-link-hover transition duration-200">
        Next &rarr;
      </a>
    )}
  </nav>
</Blog>
