---
import Blog from '../../../../layouts/Blog.astro'
import { getCollection } from 'astro:content'
import Card from '../../../../components/Card.astro'
import Icon from '../../../../components/Icon.astro'
import { PencilMono } from '../../../../../components/illustration'
import { categories } from '../../../../lib/categories'

const POSTS_PER_PAGE = 12

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 12
  const { categories } = await import('../../../../lib/categories')
  const allPosts = await getCollection('blog', ({ data }) => data.status === 'open')
  const paths: any[] = []

  for (const cat of categories) {
    const catPosts = allPosts.filter((p) =>
      p.data.categories.some((pc: string) => {
        const normalised = pc.replace(' ', '-').toLowerCase()
        return normalised === cat.slugAsParams.toLowerCase()
      })
    )

    const totalPages = Math.ceil(catPosts.length / POSTS_PER_PAGE)
    for (let i = 2; i <= totalPages; i++) {
      paths.push({ params: { slug: cat.slugAsParams, page: String(i) } })
    }
  }

  return paths
}

const { slug, page } = Astro.params
const pageNumber = parseInt(page!)
const data = categories.find((c: any) => c.slugAsParams === slug)

if (!data) {
  return Astro.redirect('/blog')
}

const parent = data.parent

// Get subcategories for this category
const subcategories = categories.filter((category) => {
  if (category.parent === false || category.exclude === true) return false
  if (!parent && data.title.toLowerCase() === category.parent) return true
  if (parent && category.parent === parent) return true
  return false
})

// Get posts matching this category
const allPosts = await getCollection('blog', ({ data: postData }) => {
  if (postData.status !== 'open') return false
  return postData.categories.some((cat: string) => {
    const normalised = cat.replace(' ', '-').toLowerCase()
    return normalised === slug!.toLowerCase()
  })
})

const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
const paginatedPosts = posts.slice(POSTS_PER_PAGE * (pageNumber - 1), POSTS_PER_PAGE * pageNumber)
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE)

const prevPage = pageNumber - 1 > 0
const nextPage = pageNumber + 1 <= totalPages
---

<Blog title={`${data.title} \u2013 Page ${pageNumber}`} description={data.description}>
  <PencilMono
    width={962}
    height={46}
    className="col-start-1 col-end-3 row-start-1 max-w-[initial] justify-self-end self-start mt-3 drop-shadow-placed max-2xl:hidden"
  />
  <header class="max-md:frame max-md:frame-24 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 col-container md:col-content max-md:px-8 max-md:py-12">
    <div class="flex flex-col gap-4 md:col-span-1">
      <h1 class="w-full text-heading font-display lowercase self-start min-w-0 min-h-0 font-variation-bold lg:font-variation-extrabold text-3xl xs:text-5xl lg:text-7xl">
        {data.title}
      </h1>
      <p class="md:text-lg lg:text-xl text-ui-body sm:max-w-[34ch]">{data.description}</p>
    </div>
    <ul class="md:col-span-1 grid grid-cols-2 gap-x-4 md:gap-x-8 self-end column-categories lg:-mb-2">
      {subcategories.map((category) => (
        <li class="self-end">
          <a
            href={category.slug}
            class="py-2 md:py-3 text-base md:text-lg lg:text-xl hover:text-link-hover transition duration-200 ease-linear font-ui lowercase leading-none rounded flex gap-2 items-center text-current"
          >
            <Icon class="text-current shrink-0" icon={category.icon} size={24} variant="header" />
            {category.title}
          </a>
        </li>
      ))}
    </ul>
  </header>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 col-container md:col-content gap-8">
    {paginatedPosts.length > 0 ? (
      paginatedPosts.map((post) => <Card post={post} image={true} size="container" />)
    ) : (
      <p>No posts in this category yet.</p>
    )}
  </div>
  <nav class="col-content flex justify-between items-center -my-2 relative" aria-label="Pagination">
    {prevPage ? (
      <a
        href={pageNumber - 1 === 1 ? `/category/${slug}` : `/category/${slug}/page/${pageNumber - 1}`}
        class="flex items-center gap-1 text-xl font-ui lowercase leading-[1.1428571429] py-2 transition duration-200 hover:text-link-hover"
        rel="prev"
      >
        <Icon icon="angle-left" class="stroke-current relative -top-px" size={24} />
        Newer
      </a>
    ) : (
      <button class="flex items-center gap-1 text-xl font-ui lowercase leading-[1.1428571429] py-2 cursor-not-allowed text-ui-body/70" disabled>
        <Icon icon="angle-left" class="stroke-current relative -top-px" size={24} />
        Newer
      </button>
    )}
    <span
      class="absolute left-1/2 transform -translate-x-1/2 text-xl font-ui lowercase text-ui-body flex items-center gap-1 leading-[1.1428571429] py-2"
      style="font-variant-numeric: lining-nums tabular-nums ordinal; font-feature-settings: 'dlig' on, 'case' on;"
    >
      {pageNumber} of {totalPages}
    </span>
    {nextPage ? (
      <a
        href={`/category/${slug}/page/${pageNumber + 1}`}
        class="flex items-center gap-1 text-xl font-ui lowercase leading-[1.1428571429] py-2 transition duration-200 hover:text-link-hover"
        rel="next"
      >
        Older
        <Icon icon="angle-right" class="stroke-current relative -top-px" size={24} />
      </a>
    ) : (
      <button class="flex items-center gap-1 text-xl font-ui lowercase leading-[1.1428571429] py-2 cursor-not-allowed text-ui-body/70" disabled>
        Older
        <Icon icon="angle-right" class="stroke-current relative -top-px" size={24} />
      </button>
    )}
  </nav>
</Blog>
