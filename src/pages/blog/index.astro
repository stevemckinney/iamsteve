---
import Blog from '../../layouts/Blog.astro'
import { getCollection } from 'astro:content'
import Card from '../../components/Card.astro'
import Badge from '../../components/Badge.astro'
import { categories } from '../../lib/categories'

const POSTS_PER_PAGE = 12

const allPosts = await getCollection('blog', ({ data }) => data.status === 'open')
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
const paginatedPosts = posts.slice(0, POSTS_PER_PAGE)
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE)

const topCategories = categories.filter((c) => !c.parent && !c.exclude)
---

<Blog title="Blog archive" description="Tips and tutorials about the design and build of web interfaces">
  <header class="max-md:frame max-md:frame-24 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 col-container md:col-content max-md:px-8 max-md:py-12">
    <div class="flex flex-col gap-4 md:col-span-1">
      <h1 class="w-full text-heading font-display lowercase self-start min-w-0 min-h-0 font-variation-bold lg:font-variation-extrabold text-3xl xs:text-5xl lg:text-7xl">
        Blog
      </h1>
      <p class="md:text-lg lg:text-xl text-ui-body sm:max-w-[34ch]">
        Tips and tutorials about the design and build of web interfaces
      </p>
    </div>
    <ul class="md:col-span-1 grid grid-cols-2 gap-x-8 self-end -mb-2 lg:-mb-3">
      {topCategories.map((category) => (
        <li class="self-end">
          <a
            href={`/category/${category.slugAsParams}`}
            class="py-2 md:py-3 text-base md:text-lg lg:text-xl text-emphasis hover:text-link-hover transition-all duration-200 ease-linear font-ui lowercase leading-none rounded flex gap-2 items-center text-current"
          >
            {category.title}
          </a>
        </li>
      ))}
    </ul>
  </header>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 col-container md:col-content gap-8">
    {paginatedPosts.map((post) => <Card post={post} image={true} size="container" />)}
  </div>
  {totalPages > 1 && (
    <nav class="col-content flex items-center justify-center gap-4 pt-8" aria-label="Pagination">
      <span class="text-ui-body opacity-50">Page 1 of {totalPages}</span>
      <a href="/blog/page/2" class="text-emphasis hover:text-link-hover transition duration-200">
        Next &rarr;
      </a>
    </nav>
  )}
</Blog>
