---
import Page from '../layouts/Page.astro'
import { getCollection } from 'astro:content'
import Card from '../components/Card.astro'
import Subscribe from '../components/react/Subscribe'
import Notepad from '../components/react/Notepad'
import { PencilMono } from '../../components/illustration'

const includedIds = [165, 164, 72, 157, 160]
const allPosts = await getCollection('blog', ({ data }) => data.status === 'open')
const posts = allPosts.filter((post) => includedIds.includes(post.data.id))
---

<Page title="Newsletter" description="Subscribe to get notified when new posts go out">
  <PencilMono
    width={962}
    height={46}
    className="col-start-1 col-end-3 row-start-1 max-w-[initial] justify-self-end self-start mt-3 drop-shadow-placed max-2xl:hidden"
  />
  <article class="grid grid-cols-subgrid col-content pb-18 gap-y-18">
    <header class="max-md:frame max-md:frame-24 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 col-content max-md:px-8 max-md:py-12">
      <div class="flex flex-col gap-4">
        <h1 class="w-full text-heading font-display lowercase self-start min-w-0 min-h-0 font-variation-bold lg:font-variation-extrabold text-3xl xs:text-5xl lg:text-7xl">
          Newsletter
        </h1>
      </div>
    </header>
    <div class="col-start-content-start max-lg:col-end-content-end lg:col-span-5 xl:col-span-7 2xl:col-span-6 flex flex-col gap-8">
      <section class="flex flex-col gap-4">
        <h2 class="text-3xl font-display font-variation-bold leading-none lowercase text-heading m-0">
          Get the articles
        </h2>
        <div class="bg-surface shadow-placed px-10 py-8 rounded-lg flex flex-col gap-4">
          <p>
            Join my email list and I\u2019ll notify you when the latest posts go
            out\u2014if that\u2019s what you prefer. This happens monthly at most. You
            can unsubscribe anytime.
          </p>
          <Subscribe client:visible unique="page" />
        </div>
      </section>
      <Notepad client:idle>
        <Notepad.Header>Previous issues</Notepad.Header>
        <Notepad.Body>
          <p class="text-lg text-ui-body">Previous issues will appear here.</p>
        </Notepad.Body>
      </Notepad>
    </div>
    <div class="col-start-content-start col-end-content-end lg:col-start-6 xl:col-start-9 2xl:col-start-8 flex flex-col gap-4">
      <h2 class="text-3xl font-display font-variation-bold leading-none lowercase text-heading m-0">
        What you can expect
      </h2>
      {posts.map((post) => (
        <Card size="small" post={post} />
      ))}
    </div>
  </article>
</Page>
